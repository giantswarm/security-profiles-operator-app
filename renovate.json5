{
  extends: [
    // Base config - https://github.com/giantswarm/renovate-presets/blob/main/default.json5
    "github>giantswarm/renovate-presets:default.json5",
    "github>giantswarm/renovate-presets:disable-upstream-charts.json5",
  ],
  regexManagers: [
    {
      fileMatch: ["helm/.*/values\\.yaml$", "helm/.*/values\\.schema\\.json$", "helm/.*/README\\.md$"],
      matchStrings: [
        "kubernetes-sigs/security-profiles-operator/blob/v(?<currentValue>[^/]+)/",
      ],
      depNameTemplate: "kubernetes-sigs/security-profiles-operator",
      datasourceTemplate: "github-releases",
    },
  ],
  packageRules: [
    {
      groupName: "security-profiles-operator",
      branchPrefix: "renovate/",
      matchDepNames: ["kubernetes-sigs/security-profiles-operator"],
    },
  ],
}
